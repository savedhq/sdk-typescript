{
  "name": "@saved/client",
  "version": "1.0.0",
  "description": "OpenAPI client for @saved/client",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/savedhq/sdk-typescript.git"
  },
  "scripts": {
    "generate": "npx @hey-api/openapi-ts"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.9.0",
    "@hey-api/openapi-ts": "^0.94.0",
    "typescript": "^4.0 || ^5.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
